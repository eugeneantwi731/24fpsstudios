  /* ────────────────────────────────────────
     BIO FILE EXTRACTION
  ──────────────────────────────────────── */
  const bioFileInput = document.getElementById('bio-file');
  const bioFileName  = document.getElementById('bio-file-name');
  const bioFileNote  = document.getElementById('bio-file-note');

  if (bioFileInput) {
      bioFileInput.addEventListener('change', async () => {
      const file = bioFileInput.files[0];
      if (!file) return;
      bioFileName.textContent = file.name;
      bioFileNote.textContent = 'Extracting text…';

      try {
        let text = '';
        const ext = file.name.split('.').pop().toLowerCase();

        if (ext === 'txt' || file.type === 'text/plain') {
          text = await file.text();
        } else if (ext === 'docx' || file.type === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document') {
          // Basic DOCX: unzip and grab document.xml text content
          const arrayBuffer = await file.arrayBuffer();
          const uint8 = new Uint8Array(arrayBuffer);
          // Try to read raw text (simple fallback - not full DOCX parse)
          const decoder = new TextDecoder('utf-8');
          const raw = decoder.decode(uint8);
          const textMatch = raw.match(/<w:t[^>]*>([^<]+)<\/w:t>/g);
          if (textMatch) {
            text = textMatch.map(m => m.replace(/<[^>]+>/g, '')).join(' ');
          } else {
            text = raw.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
          }
        } else {
          // PDF: attempt to read as text (works for text-based PDFs)
          const arrayBuffer = await file.arrayBuffer();
          const decoder = new TextDecoder('latin1');
          const raw = decoder.decode(arrayBuffer);
          // Extract text between BT/ET markers (basic PDF text extraction)
          const btMatches = [...raw.matchAll(/BT([\s\S]*?)ET/g)];
          if (btMatches.length) {
            text = btMatches.map(m => {
              return m[1].replace(/\((.*?)\)\s*Tj/g, '$1 ')
                        .replace(/\[(.*?)\]\s*TJ/g, (_,g) => g.replace(/\((.*?)\)/g,'$1'))
                        .replace(/[\x00-\x1F]+/g, ' ').trim();
            }).join(' ');
          }
          if (!text.trim()) text = raw.replace(/[^\x20-\x7E]/g, ' ').replace(/\s+/g, ' ').trim();
        }

        // Clean up and trim to 600 chars
        text = text.replace(/\s+/g, ' ').trim().slice(0, 600);
        if (text.length > 10) {
          bioTa.value = text;
          bioCount.textContent = text.length;
          charCount.classList.toggle('over', text.length > 580);
          bioFileNote.textContent = '✓ Text extracted - review and edit as needed.';
        } else {
          bioFileNote.textContent = 'Could not extract text. Please type your bio manually.';
        }
      } catch {
        bioFileNote.textContent = 'Extraction failed. Please type your bio manually.';
      }
    });
  }

  /* ────────────────────────────────────────
     EXPERTISE TAGS
  ──────────────────────────────────────── */
  const tagInput  = document.getElementById('expertise-text');
  const tagsList  = document.getElementById('tags-list');
  const addTagBtn = document.getElementById('add-tag-btn');
  const tagsHidden = document.getElementById('expertise-hidden');

  function renderTags() {
    tagsList.innerHTML = '';
    tags.forEach((tag, i) => {
      const el = document.createElement('span');
      el.className = 'tag';
      el.dataset.ci = i % TAG_COLORS;
      el.innerHTML = `${escapeHtml(tag)}<button type="button" class="tag-remove" data-i="${i}" aria-label="Remove ${tag}">
        <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <line x1="2" y1="2" x2="10" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <line x1="10" y1="2" x2="2" y2="10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </button>`;
      tagsList.appendChild(el);
    });
    tagsHidden.value = JSON.stringify(tags);
  }

  function addTag() {
    const val = tagInput.value.trim().replace(/,$/, '');
    if (val && !tags.includes(val)) {
      tags.push(val);
      renderTags();
    }
    tagInput.value = '';
    tagInput.focus();
  }

  addTagBtn.addEventListener('click', addTag);
  tagInput.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ',') { e.preventDefault(); addTag(); }
    if (e.key === 'Backspace' && !tagInput.value && tags.length) {
      tags.pop(); renderTags();
    }
  });
  tagsList.addEventListener('click', e => {
    const btn = e.target.closest('.tag-remove');
    if (btn) { tags.splice(parseInt(btn.dataset.i), 1); renderTags(); }
  });

  /* ────────────────────────────────────────
     SOCIAL LINKS BUILDER
  ──────────────────────────────────────── */
  const socialsBuilder = document.getElementById('socials-builder');
  const addSocialBtn   = document.getElementById('add-social-btn');
  const socialsHidden  = document.getElementById('socials-hidden');

  function updateSocials() {
    const obj = {};
    socialsBuilder.querySelectorAll('.social-row').forEach(row => {
      const p = row.dataset.platform || '';
      const u = row.querySelector('.social-url').value.trim();
      if (p && u) obj[p] = u;
    });
    socialsHidden.value = JSON.stringify(obj);
  }

  function getPlaceholder(platform) {
    return PLATFORMS.find(p => p.value === platform)?.placeholder || 'https://…';
  }

/* Close all open custom dropdowns except the one passed in */
  function closeAllDropdowns(except = null) {
    document.querySelectorAll('.social-dropdown.is-open').forEach(d => {
      if (d !== except) {
        d.classList.remove('is-open');
        d.setAttribute('aria-expanded', 'false');
        // FIX: Look in the parent wrapper to find the list, not inside the button
        const list = d.parentElement.querySelector('.social-dd-list');
        if (list) list.style.display = 'none';
      }
    });
  }

  function buildCustomDropdown(selectedValue = '') {
    const selected = PLATFORMS.find(p => p.value === selectedValue) || null;

    const wrap = document.createElement('div');
    wrap.className = 'social-select-wrap';

    const trigger = document.createElement('button');
    trigger.type = 'button';
    trigger.className = 'social-dropdown';
    trigger.setAttribute('aria-haspopup', 'listbox');
    trigger.setAttribute('aria-expanded', 'false');

    const triggerIcon = document.createElement('span');
    triggerIcon.className = 'social-dd-icon';
    triggerIcon.innerHTML = selected ? selected.icon : `<svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="1.5" fill="currentColor"/><circle cx="12" cy="12" r="1.5" fill="currentColor"/><circle cx="12" cy="16" r="1.5" fill="currentColor"/></svg>`;

    const triggerLabel = document.createElement('span');
    triggerLabel.className = 'social-dd-label';
    triggerLabel.textContent = selected ? selected.label : 'Select platform';

    const caret = document.createElement('span');
    caret.className = 'social-dd-caret';
    caret.innerHTML = `<svg viewBox="0 0 16 16" fill="none"><path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>`;

    trigger.appendChild(triggerIcon);
    trigger.appendChild(triggerLabel);
    trigger.appendChild(caret);

    const list = document.createElement('ul');
    list.className = 'social-dd-list';
    list.setAttribute('role', 'listbox');
    list.style.display = 'none';

    PLATFORMS.forEach(p => {
      const item = document.createElement('li');
      item.className = 'social-dd-item' + (p.value === selectedValue ? ' is-selected' : '');
      item.setAttribute('role', 'option');
      item.dataset.value = p.value;
      item.innerHTML = `<span class="social-dd-item-icon">${p.icon}</span><span>${p.label}</span>`;
      item.addEventListener('mousedown', e => {
        e.preventDefault();
        // Update trigger UI
        triggerIcon.innerHTML = p.icon;
        triggerLabel.textContent = p.label;
        // Mark selection
        list.querySelectorAll('.social-dd-item').forEach(i => i.classList.remove('is-selected'));
        item.classList.add('is-selected');
        // Store selected value on the row
        const row = wrap.closest('.social-row');
        row.dataset.platform = p.value;
        // Update URL placeholder
        const urlInput = row.querySelector('.social-url');
        urlInput.placeholder = p.placeholder;
        // Close and update
        trigger.classList.remove('is-open');
        list.style.display = 'none';
        trigger.setAttribute('aria-expanded', 'false');
        updateSocials();
      });
      list.appendChild(item);
    });

trigger.addEventListener('click', () => {
      const isOpen = trigger.classList.contains('is-open');
      
      // Close all OTHER dropdowns so they don't overlap
      closeAllDropdowns(trigger);

      if (isOpen) {
        trigger.classList.remove('is-open');
        list.style.display = 'none';
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        // Otherwise, open it downwards
        trigger.classList.add('is-open');
        list.style.display = 'block';
        trigger.setAttribute('aria-expanded', 'true');
        
        // Ensure it always resets to drop down (in case it got stuck)
        list.style.top = 'calc(100% + 6px)';
        list.style.bottom = 'auto';
      }
    });

    // Close on outside click
    document.addEventListener('click', e => {
      if (!wrap.contains(e.target)) {
        trigger.classList.remove('is-open');
        list.style.display = 'none';
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    wrap.appendChild(trigger);
    wrap.appendChild(list);
    return wrap;
  }

  function addSocialRow(platform = '', url = '') {
    const row = document.createElement('div');
    row.className = 'social-row';
    row.dataset.platform = platform;

    const ddWrap = buildCustomDropdown(platform);

    const urlInput = document.createElement('input');
    urlInput.type = 'url';
    urlInput.className = 'social-url';
    urlInput.placeholder = getPlaceholder(platform) || 'Paste your profile URL';
    urlInput.value = url;
    urlInput.addEventListener('input', updateSocials);

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'social-remove';
    removeBtn.setAttribute('aria-label', 'Remove link');
    removeBtn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M3 6H21M5 6V20C5 21.1046 5.89543 22 7 22H17C18.1046 22 19 21.1046 19 20V6M8 6V4C8 2.89543 8.89543 2 10 2H14C15.1046 2 16 2.89543 16 4V6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M14 11V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M10 11V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>`;
    removeBtn.addEventListener('click', () => { row.remove(); updateSocials(); });

    row.appendChild(ddWrap);
    row.appendChild(urlInput);
    row.appendChild(removeBtn);
    socialsBuilder.appendChild(row);
  }

  addSocialBtn.addEventListener('click', () => addSocialRow());

  /* ────────────────────────────────────────
     CATEGORY CUSTOM DROPDOWN
