  /* ────────────────────────────────────────
     PHOTO UPLOAD
  ──────────────────────────────────────── */
  const photoInput     = document.getElementById('photo');
  const uploadZone     = document.getElementById('upload-zone');
  const uploadUi       = document.getElementById('upload-ui');
  const avatarPreview  = document.getElementById('avatar-preview-img');

  function showPreview(file) {
    if (!file || file.size > 5 * 1024 * 1024) {
      if (file) alert('Photo must be under 5MB.');
      photoInput.value = '';
      return;
    }
    const reader = new FileReader();
    reader.onload = e => {
      avatarPreview.src = e.target.result;
      uploadUi.querySelector('.upload-text').innerHTML = 'Photo selected ✓<br/><span style="font-weight:500;font-size:0.8em;color:var(--muted)">Click to change</span>';
    };
    reader.readAsDataURL(file);
  }

  photoInput.addEventListener('change', () => showPreview(photoInput.files[0]));
  uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('dragover'); });
  uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('dragover'));
  uploadZone.addEventListener('drop', e => {
    e.preventDefault();
    uploadZone.classList.remove('dragover');
    const f = e.dataTransfer.files[0];
    if (f?.type.startsWith('image/')) {
      const dt = new DataTransfer(); dt.items.add(f); photoInput.files = dt.files;
      showPreview(f);
    }
  });

  /* ────────────────────────────────────────
     VALIDATION
  ──────────────────────────────────────── */
  function setError(fieldId, errId, msg) {
    const el = document.getElementById(fieldId);
    const err = document.getElementById(errId);
    if (msg) { el?.classList.add('is-error'); if (err) err.textContent = msg; }
    else      { el?.classList.remove('is-error'); if (err) err.textContent = ''; }
  }

  function validate() {
    let ok = true;
    const v = id => (document.getElementById(id)?.value || '').trim();

    if (v('full-name').length < 2) { setError('full-name','err-full-name','Please enter your full name.'); ok = false; }
    else setError('full-name','err-full-name','');

    if (v('initials').length < 2) { setError('initials','err-initials','Enter 2–3 character initials.'); ok = false; }
    else setError('initials','err-initials','');

    if (!v('category')) { setError('category-btn','err-category','Please select your status.'); ok = false; }
    else setError('category-btn','err-category','');

    if (v('role').length < 2) { setError('role','err-role','Please enter your role / title.'); ok = false; }
    else setError('role','err-role','');

    if (tags.length === 0) { document.getElementById('err-expertise').textContent = 'Add at least one skill.'; ok = false; }
    else document.getElementById('err-expertise').textContent = '';

    const bioVal = v('bio');
    if (bioVal.length < 30)  { setError('bio','err-bio','Bio must be at least 30 characters.'); ok = false; }
    else setError('bio','err-bio','');

    const emailVal = v('email');
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal)) { setError('email','err-email','Please enter a valid email address.'); ok = false; }
    else setError('email','err-email','');

    const portVal = v('portfolio');
    if (portVal && !portVal.startsWith('http')) { setError('portfolio','err-portfolio','Please enter a valid URL starting with http.'); ok = false; }
    else setError('portfolio','err-portfolio','');

    return ok;
  }

  /* ────────────────────────────────────────
     REVIEW MODAL BUILD
  ──────────────────────────────────────── */
  function buildReview() {
    const v = id => (document.getElementById(id)?.value || '').trim();

    const rows = [
      { key: 'Full Name',       val: v('full-name') },
      { key: 'Nickname',        val: v('nickname') || '-' },
      { key: 'Initials',        val: v('initials') },
      { key: 'Category',        val: v('category') },
      { key: 'Program',         val: v('program') || '-' },
      { key: 'Role / Title',    val: v('role') },
      { key: 'Expertise',       val: '__tags__' },
      { key: 'Bio',             val: v('bio') },
      { key: 'Email',           val: v('email') },
      { key: 'Portfolio',       val: v('portfolio') },
      { key: 'Social Links',    val: '__socials__' },
      { key: 'Photo',           val: photoInput.files[0]?.name || 'None (avatar will be created)' },
    ];

    reviewBody.innerHTML = '';
    rows.forEach(r => {
      const row = document.createElement('div');
      row.className = 'review-row';
      let valHtml = '';
      if (r.val === '__tags__') {
        valHtml = tags.map((t, i) =>
          `<span class="tag" data-ci="${i % TAG_COLORS}" style="margin:2px;">${escapeHtml(t)}</span>`
        ).join('') || '-';
      } else if (r.val === '__socials__') {
        const s = JSON.parse(socialsHidden.value || '{}');
        const entries = Object.entries(s);
        valHtml = entries.length
          ? entries.map(([p,u]) => `<div><strong>${p}:</strong> ${escapeHtml(u)}</div>`).join('')
          : '-';
      } else {
        valHtml = escapeHtml(r.val);
      }
      row.innerHTML = `<span class="review-key">${r.key}</span><span class="review-val">${valHtml}</span>`;
      reviewBody.appendChild(row);
    });
  }

  /* ────────────────────────────────────────
     DUPLICATE CHECK
  ──────────────────────────────────────── */
  async function checkDuplicate(email) {
    try {
      const res = await fetch(
        `${SUPABASE_URL}/rest/v1/member_submissions?select=id&email=eq.${encodeURIComponent(email)}&status=in.(pending,approved)`,
        { headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${SUPABASE_ANON}` } }
      );
      const data = await res.json();
      return Array.isArray(data) && data.length > 0;
    } catch { return false; }
  }

  /* ────────────────────────────────────────
     PHOTO UPLOAD TO SUPABASE STORAGE
  ──────────────────────────────────────── */
  async function uploadPhoto(file, name) {
    if (!file) return null;
    const ext  = file.name.split('.').pop();
    const path = `${Date.now()}-${name.toLowerCase().replace(/\s+/g,'-')}.${ext}`;
    const res  = await fetch(`${SUPABASE_URL}/storage/v1/object/member-photos/${path}`, {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${SUPABASE_ANON}`, 'Content-Type': file.type },
      body: file,
    });
    if (!res.ok) return null;
    return `${SUPABASE_URL}/storage/v1/object/public/member-photos/${path}`;
  }

  /* ────────────────────────────────────────
     FORM SUBMIT → REVIEW MODAL
  ──────────────────────────────────────── */
  form.addEventListener('submit', e => {
    e.preventDefault();
    if (!validate()) {
      document.querySelector('.is-error')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    buildReview();
    overlay.style.display = 'flex';
    overlay.scrollTop = 0;
  });

  btnEdit.addEventListener('click', () => { overlay.style.display = 'none'; });
  overlay.addEventListener('click', e => { if (e.target === overlay) overlay.style.display = 'none'; });

  /* ────────────────────────────────────────
     CONFIRM SUBMIT → SUPABASE
  ──────────────────────────────────────── */
  btnConfirm.addEventListener('click', async () => {
    btnConfirm.disabled = true;
    btnConfirm.textContent = 'Submitting…';

    const v = id => (document.getElementById(id)?.value || '').trim();
    const email = v('email');

    // Duplicate guard
    const isDuplicate = await checkDuplicate(email);
    if (isDuplicate) {
      overlay.style.display = 'none';
      alert(`A submission with the email "${email}" already exists and is under review or approved. You can only submit once.`);
      btnConfirm.disabled = false;
      btnConfirm.textContent = 'Confirm & Submit';
      return;
    }

    try {
      const photoUrl = await uploadPhoto(photoInput.files[0], v('full-name'));

      const payload = {
        name:       v('full-name'),
        nickname:   v('nickname') || null,
        initials:   v('initials'),
        category:   v('category'),
        program:    v('program') || null,
        role:       v('role'),
        expertise:  tags,
        bio:        v('bio'),
        email,
        portfolio:  v('portfolio'),
        socials:    JSON.parse(socialsHidden.value || '{}'),
        photo_url:  photoUrl,
        status:     'pending',
      };

      const res = await fetch(`${SUPABASE_URL}/rest/v1/member_submissions`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON,
          'Authorization': `Bearer ${SUPABASE_ANON}`,
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error('Submission failed');

      overlay.style.display = 'none';
      form.style.display = 'none';
      document.querySelector('.submit-strip').style.display = 'none';
      successState.style.display = 'block';
      successState.scrollIntoView({ behavior: 'smooth', block: 'center' });

    } catch {
      overlay.style.display = 'none';
      btnConfirm.disabled = false;
      btnConfirm.textContent = 'Confirm & Submit';
      alert('Something went wrong. Please check your connection and try again.');
    }
  });

  /* Underline width is handled by CSS (inline-flex on .section__title-wrap). */

  /* ────────────────────────────────────────
     SYNC UPLOAD ZONE HEIGHT TO PREVIEW CARD
  ──────────────────────────────────────── */
  function syncUploadHeight() {
    const card = document.getElementById('photo-preview-card');
    const zone = document.getElementById('upload-zone');
    if (card && zone) {
      const h = card.offsetHeight;
      if (h > 0) zone.style.height = h + 'px';
    }
  }
  syncUploadHeight();
  window.addEventListener('resize', syncUploadHeight);

  /* ────────────────────────────────────────
     CLEAR ERRORS ON INPUT
  ──────────────────────────────────────── */
  ['full-name','initials','role','bio','email','portfolio'].forEach(id => {
    const el = document.getElementById(id);
    const errEl = document.getElementById(`err-${id}`);
    el?.addEventListener('input', () => { el.classList.remove('is-error'); if (errEl) errEl.textContent = ''; });
    el?.addEventListener('change', () => { el.classList.remove('is-error'); if (errEl) errEl.textContent = ''; });
  });
  tagInput.addEventListener('input', () => { document.getElementById('err-expertise').textContent = ''; });

  /* ────────────────────────────────────────
     HELPERS
  ──────────────────────────────────────── */
  function escapeHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
  }
</script>
