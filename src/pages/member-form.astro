  /* ────────────────────────────────────────
     BIO CHARACTER COUNTER
  ──────────────────────────────────────── */
  const bioTa    = document.getElementById('bio');
  const bioCount = document.getElementById('bio-count');
  const charCount = document.querySelector('.char-count');
  bioTa.addEventListener('input', () => {
    const len = bioTa.value.length;
    if (len > 600) bioTa.value = bioTa.value.slice(0, 600);
    bioCount.textContent = Math.min(len, 600);
    charCount.classList.toggle('over', len > 580);
