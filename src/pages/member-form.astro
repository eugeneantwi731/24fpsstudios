---
// src/pages/member-form.astro
// 24fps Decode Animation Lab - Member Profile Submission Form
// No Navbar or Footer - standalone page shared via WhatsApp link
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Member Profile Submission - 24fps Decode Animation Lab</title>
  <link rel="icon" type="image/svg+xml" href="/images/24fps-favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>

<body>

  <!-- ── PAGE WRAPPER ── -->
  <main class="page">

    <!-- Decorative scribbles – sit on the page background, not inside hero -->
    <img src="./images/crown-scribble.svg"      class="deco deco--crown"     alt="" aria-hidden="true" />
    <img src="./images/film-strip.svg"           class="deco deco--film"      alt="" aria-hidden="true" />
    <img src="./images/star-scribble-1.svg"      class="deco deco--star1"     alt="" aria-hidden="true" />
    <img src="./images/star-scribble-2.svg"      class="deco deco--star2"     alt="" aria-hidden="true" />
    <img src="./images/cross-scribble-1.svg"     class="deco deco--cross1"    alt="" aria-hidden="true" />
    <img src="./images/cross-scribble-2.svg"     class="deco deco--cross2"    alt="" aria-hidden="true" />
    <img src="./images/line-scribble.svg"        class="deco deco--line"      alt="" aria-hidden="true" />
    <img src="./images/star-line-scribble.svg"   class="deco deco--starline"  alt="" aria-hidden="true" />

    <!-- ── HERO ── -->
    <header class="hero">
      <div class="hero__inner">
        <!-- Logo -->
        <a href="/" class="hero__logo" aria-label="24fps Home">
          <img src="./images/24fps-header-logo.svg" alt="24fps Decode Animation Lab" />
        </a>

        <div class="hero__title-wrap">
          <h1 class="hero__title">
            MEMBER PROFILE<br/>
            <span class="hero__title--pink">SUBMISSION FORM</span>
          </h1>
          <img src="./images/three-sparks.svg" class="sparks-inline" alt="" aria-hidden="true" />
        </div>
        <p class="hero__sub">
          This form collects the information that will appear on your official
          profile page on the 24fps Decode Animation Lab website.
          Take your time - this is how the world sees you.
        </p>
      </div>
    </header>

    <!-- ── FORM BODY ── -->
    <section class="form-wrap">
      <form id="member-form" novalidate>

        <!-- ══ SECTION 01: IDENTITY ══ -->
        <div class="section" id="sec-01">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--pink)">01</span>
                <div class="section__title-wrap">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Identity</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#E9295D"/></svg>
                  </div>
                  <p class="section__sub">Who are you?</p>
                </div>
            </div>
            <div class="section__icon-bg">
              <img src="./images/identity-icon.svg" alt="" aria-hidden="true" />
            </div>
          </div>
          <div class="fields fields--identity">
            <div class="field">
              <label class="label" for="full-name">Full Name <span class="req">*</span></label>
              <input class="input" id="full-name" name="full_name" type="text"
                     placeholder="e.g. John Delali Attah" autocomplete="name" required />
              <span class="err" id="err-full-name"></span>
            </div>
            <div class="field">
              <label class="label" for="initials">Initials <span class="req">*</span></label>
              <input class="input" id="initials" name="initials" type="text"
                     placeholder="e.g. JDA" maxlength="3" required />
              <span class="hint">2–3 characters from your name</span>
              <span class="err" id="err-initials"></span>
            </div>
            <div class="field field--nickname">
              <label class="label" for="nickname">Nickname <span class="opt">optional</span></label>
              <input class="input" id="nickname" name="nickname" type="text" placeholder="e.g. Hohoe Dr. Strange" />
            </div>
          </div>
        </div>

        <!-- ══ SECTION 02: YOUR ROLE ══ -->
        <div class="section" id="sec-02">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--teal)">02</span>
                <div class="section__title-wrap">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Your Role</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#3FD3D5"/></svg>
                  </div>
                  <p class="section__sub">Where do you fit in the studio?</p>
                </div>
            </div>
            <div class="section__icon-bg">
              <img src="./images/your-role-icon.svg" alt="" aria-hidden="true" />
            </div>
          </div>
          <div class="fields fields--3">

            <!-- Category -->
            <div class="field">
              <label class="label" for="category-btn">Status <span class="req">*</span></label>
              <div class="category-dd-wrap" id="category-dd-wrap">
                <button type="button" class="input category-dd-trigger" id="category-btn"
                        aria-haspopup="listbox" aria-expanded="false">
                  <span class="category-dd-label" id="category-dd-label">Student, Alumni or Faculty?</span>
                  <svg class="category-dd-caret" viewBox="0 0 16 16" fill="none">
                    <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                </button>
                <ul class="category-dd-list" id="category-dd-list" role="listbox" style="display:none">
                  <li class="category-dd-item" role="option" data-value="student">Student</li>
                  <li class="category-dd-item" role="option" data-value="alumni">Alumni</li>
                  <li class="category-dd-item" role="option" data-value="faculty">Faculty</li>
                </ul>
              </div>
              <input type="hidden" id="category" name="category" required />
              <span class="err" id="err-category"></span>
            </div>

            <!-- Program - text input, not dropdown -->
            <div class="field">
              <label class="label" for="program">Program <span class="opt">optional</span></label>
              <input class="input" id="program" name="program" type="text"
                     placeholder="e.g. Communication Design" />
              <span class="hint">Your department / programme</span>
            </div>

            <!-- Role / Title -->
            <div class="field">
              <label class="label" for="role">Role / Title <span class="req">*</span></label>
              <input class="input" id="role" name="role" type="text"
                     placeholder="e.g. 3D Modeler, Sound Designer" required />
              <span class="hint">Your specific studio role</span>
              <span class="err" id="err-role"></span>
            </div>
          </div>
        </div>

        <!-- ══ SECTION 03: EXPERTISE ══ -->
        <div class="section" id="sec-03">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--yellow)">03</span>
                <div class="section__title-wrap">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Expertise</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#FEC843"/></svg>
                  </div>
                  <p class="section__sub">What are your skills?</p>
                </div>
            </div>
            <div class="section__icon-bg">
              <img src="./images/expertise-icon.svg" alt="" aria-hidden="true" />
            </div>
          </div>

          <p class="section__instructions">
            Add your skills. Type a skill and press Enter to add.<br/>
            <strong>* At least one skill is required.</strong>
          </p>

          <div class="tag-input-wrap" id="tag-wrap">
            <div class="tag-input-row">
              <input class="input tag-input" id="expertise-text" type="text"
                     placeholder="Type a skill and press Enter…" autocomplete="off" />
              <button type="button" class="add-tag-btn" id="add-tag-btn" aria-label="Add skill">
                <svg viewBox="0 0 16 16" fill="none">
                  <line x1="8" y1="2" x2="8" y2="14" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                  <line x1="2" y1="8" x2="14" y2="8" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                </svg>
                Add
              </button>
            </div>
            <div class="tags-list" id="tags-list"></div>
          </div>
          <span class="err" id="err-expertise"></span>
          <input type="hidden" id="expertise-hidden" name="expertise" />
        </div>

        <!-- ══ SECTION 04: BIO ══ -->
        <div class="section" id="sec-04">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--purple)">04</span>
                <div class="section__title-wrap">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Your Bio</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#9F6ACD"/></svg>
                  </div>
                  <p class="section__sub">Tell the world who you are.</p>
                </div>
            </div>
            <div class="section__icon-bg">
              <img src="./images/your-bio-icon.svg" alt="" aria-hidden="true" />
            </div>
          </div>

          <p class="section__instructions">
            Tell us about yourself, your interests, and what drives your creativity.
            <strong>Minimum 30 characters. Maximum 600 characters.</strong>
          </p>


          <div class="field">
            <label class="label" for="bio">Bio <span class="req">*</span></label>
            <textarea class="input textarea" id="bio" name="bio" rows="5"
              placeholder="Write 2–4 sentences about yourself - your role at 24fps, what you work on, and what drives your creative practice."
              required></textarea>
            <div class="bio-footer">
              <span class="err" id="err-bio"></span>
              <span class="char-count"><span id="bio-count">0</span> / 600</span>
            </div>
          </div>
        </div>

        <!-- ══ SECTION 05: CONTACT & PORTFOLIO ══ -->
        <div class="section" id="sec-05">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--pink)">05</span>
                <div class="section__title-wrap">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Contact &amp; Portfolio</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#E9295D"/></svg>
                  </div>
                  <p class="section__sub">How can people reach you?</p>
                </div>
            </div>
            <div class="section__icon-bg">
              <img src="./images/contact-portfolio-icon.svg" alt="" aria-hidden="true" />
            </div>
          </div>
          <div class="fields fields--2">
            <div class="field">
              <label class="label" for="email">Email Address <span class="req">*</span></label>
              <input class="input" id="email" name="email" type="email"
                     placeholder="e.g. you@example.com" autocomplete="email" required />
              <span class="err" id="err-email"></span>
            </div>
            <div class="field">
              <label class="label" for="portfolio">Portfolio URL <span class="opt">optional</span></label>
              <input class="input" id="portfolio" name="portfolio" type="url"
                     placeholder="e.g. https://yourportfolio.com" />
              <span class="err" id="err-portfolio"></span>
            </div>
          </div>
        </div>

        <!-- ══ SECTION 06: SOCIAL LINKS ══ -->
        <div class="section" id="sec-06">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--teal)">06</span>
              <div class="section__title-wrap">
                <div class="section__title-row">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Social Links</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#3FD3D5"/></svg>
                  </div>
                  <span class="opt-badge">optional</span>
                </div>
                <p class="section__sub">Add your social or professional links.</p>
              </div>
            </div>
            <div class="section__icon-bg">
              <img src="./images/social-links-icon.svg" alt="" aria-hidden="true" />
            </div>
          </div>

          <p class="section__instructions">
            Select a platform and paste your full profile URL. Click <strong>Add Link</strong> to add more.
          </p>

          <div class="socials-builder" id="socials-builder"></div>

          <button type="button" class="add-social-btn" id="add-social-btn">
            <svg viewBox="0 0 16 16" fill="none">
              <line x1="8" y1="2" x2="8" y2="14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              <line x1="2" y1="8" x2="14" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            Add Link
          </button>

          <input type="hidden" id="socials-hidden" name="socials" value="{}" />
        </div>

        <!-- ══ SECTION 07: PHOTO ══ -->
        <div class="section" id="sec-07">
          <div class="section__head">
            <div class="section__head-left">
              <span class="section__num" style="--clr: var(--yellow)">07</span>
              <div class="section__title-wrap">
                <div class="section__title-row">
                  <div class="section__title-underline-wrap">
                    <h2 class="section__title">Photo</h2>
                    <svg class="section__title-underline" viewBox="0 0 70.82 4.26" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M1.23 4.26c-1.11,0.11 -2.41,-2 0.49,-2.29 16.96,-1.66 44.64,-2.65 62.25,-1.38 0.87,0.06 6.9,0.29 6.84,1.21 -0.05,0.85 -5.65,0.51 -6.49,0.51 -8.2,-0.08 -14.21,-0.26 -22.66,-0.11 -13,0.24 -27.49,0.71 -40.44,2.06z" fill="#FEC843"/></svg>
                  </div>
                  <span class="opt-badge">optional</span>
                </div>
              </div>
            </div>
          </div>

          <div class="photo-layout">
            <!-- LEFT: Upload zone -->
            <div class="upload-col">
              <span class="upload-spacer" aria-hidden="true"></span>
              <div class="upload-zone" id="upload-zone">
                <input type="file" id="photo" name="photo"
                       accept="image/jpeg,image/png,image/webp"
                       class="upload-input" />
                <div class="upload-ui" id="upload-ui">
                  <img src="./images/upload-icon.svg" class="upload-icon" alt="" aria-hidden="true" />
                  <p class="upload-text">Drag &amp; drop your photo here<br/>or click to browse</p>
                  <p class="upload-hint">JPG, PNG, or WEBP • Under 5MB</p>
                </div>
              </div>
            </div>

            <!-- DIVIDER -->
            <div class="photo-divider-v" aria-hidden="true"></div>

            <!-- MIDDLE: Preview card -->
            <div class="photo-preview-col">
              <span class="preview-label">PREVIEW</span>
              <div class="photo-preview-card" id="photo-preview-card">
                <img src="./images/profile-avatar.svg" id="avatar-preview-img" alt="Avatar preview" />
              </div>
            </div>

            <!-- RIGHT: No-photo note -->
            <div class="no-photo-note">
              <p class="no-photo-text">
                <strong>No photo? No worries!</strong><br/>
                We'll create a custom illustrated avatar for you.
              </p>
              <img src="./images/arrow-line-turned.svg" class="no-photo-deco" alt="" aria-hidden="true" />
            </div>
          </div>
        </div>

        <!-- ══ REVIEW & SUBMIT ══ -->
        <div class="submit-strip">
          <p class="submit-note">
            <svg viewBox="0 0 16 16" fill="none" width="18" height="18">
              <circle cx="8" cy="8" r="6.5" stroke="var(--teal)" stroke-width="1.4"/>
              <line x1="8" y1="7" x2="8" y2="11" stroke="var(--teal)" stroke-width="1.6" stroke-linecap="round"/>
              <circle cx="8" cy="5" r="0.8" fill="var(--teal)"/>
            </svg>
            Please review your details before submitting. You can only submit once.
          </p>
          <button type="submit" class="submit-btn" id="submit-btn">
            <svg viewBox="0 0 20 20" fill="none" width="20" height="20">
              <path d="M3 10l14 0M10 4l6 6-6 6" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            SUBMIT PROFILE
          </button>
        </div>

      </form>

      <!-- ══ REVIEW MODAL ══ -->
      <div class="review-overlay" id="review-overlay" style="display:none" role="dialog" aria-modal="true" aria-labelledby="review-title">
        <div class="review-modal">
          <h2 class="review-title" id="review-title">
            <img src="./images/clapper-board-icon.svg" alt="" aria-hidden="true" />
            Review Your Profile
          </h2>
          <p class="review-sub">Check everything looks right before we send it.</p>

          <div class="review-body" id="review-body"></div>

          <div class="review-actions">
            <button type="button" class="btn-edit" id="btn-edit">
              ← Go Back &amp; Edit
            </button>
            <button type="button" class="btn-confirm" id="btn-confirm">
              Confirm &amp; Submit
            </button>
          </div>
        </div>
      </div>

      <!-- ══ SUCCESS STATE ══ -->
      <div class="success-state" id="success-state" style="display:none">
        <img src="./images/three-sparks.svg" class="success-sparks" alt="" aria-hidden="true" />
        <div class="success-check">
          <svg viewBox="0 0 60 60" fill="none">
            <circle cx="30" cy="30" r="28" stroke="var(--pink)" stroke-width="2.2"/>
            <path d="M18 30L26 38L42 22" stroke="var(--pink)" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h2 class="success-title">Profile Submitted!</h2>
        <p class="success-text">
          Your profile is now under review by the team. Once approved, it will
          go live on the 24fps website. Keep creating.
        </p>
        <div class="success-badge">DECODE · CREATE · INSPIRE</div>
      </div>

    </section>

    <!-- ── FOOTER ── -->
    <footer class="site-footer">
      <img src="./images/24fps-footer-logo.svg" alt="24fps Decode Animation Lab" class="footer-logo" />
    </footer>

  </main>

</body>
</html>

<!-- ══════════════════════════════════════════
     STYLES
══════════════════════════════════════════ -->
<style is:global>
  /* ── RESET & ROOT ── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --pink:   #E9295D;
    --teal:   #3FD3D5;
    --yellow: #FEC843;
    --purple: #9F6ACD;
    --black:  #1A1A1A;
    --white:  #FFFFFF;
    --off:    #F8F5F5;
    --muted:  #6B7280;
    --border: rgba(26,26,26,0.12);

    /* tag cycling colors */
    --tag0: var(--pink);
    --tag1: var(--teal);
    --tag2: var(--yellow);
    --tag3: var(--purple);
  }

  body {
    font-family: 'Raleway', sans-serif;
    background: var(--off);
    color: var(--black);
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* ── PAGE ── */
  .page { min-height: 100vh; position: relative; }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 64px 24px 72px;
    background: transparent;
    text-align: center;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 600px;
    margin: 0 auto;
  }

  .hero__logo {
    display: inline-block;
    margin-bottom: 24px;
  }
  .hero__logo img { height: 100px; width: auto; display: block; margin: 0 auto; }

  .hero__title {
    font-size: clamp(2.4rem, 5.5vw, 3.6rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.05;
    color: var(--black);
    margin-bottom: 16px;
  }
  .hero__title--pink { color: var(--pink); }

  .hero__sub {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
    line-height: 1.65;
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── DECORATIVE SCRIBBLES – positioned on .page ── */
  .deco {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }
  .deco--crown    { width: 90px;  top: 24px;   left: 4%; }
  .deco--film     { width: 400px; top: 0;      right: 0; opacity: 1; }
  .deco--star1    { width: 52px;  top: 140px;  left: 8%; }
  .deco--star2    { width: 56px;  top: 20px;   right: 18%; }
  .deco--cross1   { width: 36px;  top: 340px;  left: 6%; }
  .deco--cross2   { width: 38px;  top: 360px;  right: 8%; }
  .deco--line     { width: 80px;  top: 300px;  right: 16%; }
  .deco--arrow    { width: 56px;  top: 70px;   left: 22%; }
  .deco--starline { width: 60px;  top: 60px;   right: 24%; }
  .deco--sparks   { display: none; }

  /* ── SPARKS – sits inline to the right of "SUBMISSION FORM" ── */
  .hero__title-wrap {
    position: relative;
    display: inline-block;
  }
  .sparks-inline {
    position: absolute;
    width: 32px;
    right: -70px;
    bottom: 50px;
  }

  /* ── FORM WRAPPER ── */
  .form-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px 80px;
  }

  /* ── SECTION CARD BASE ── */
  .section {
    background: var(--white);
    border-radius: 24px;
    padding: 36px 40px;
    margin-top: 20px;
    position: relative;
    overflow: visible; /* Keeps dropdown content from being clipped */
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    animation: sectionIn 0.45s ease both;
    transition: box-shadow 0.4s ease;
  }

  /* ── PERMANENT DESCENDING LAYER STACK ── */
  /* This forces higher sections to always paint on top of lower sections */
  .section:nth-of-type(1) { z-index: 7; }
  .section:nth-of-type(2) { z-index: 6; }
  .section:nth-of-type(3) { z-index: 5; }
  .section:nth-of-type(4) { z-index: 4; }
  .section:nth-of-type(5) { z-index: 3; }
  .section:nth-of-type(6) { z-index: 2; } /* Your socials block */
  .section:nth-of-type(7) { z-index: 1; } /* Elements below socials */

  /* Dynamically elevates whichever card you are currently interacting with */
  .section:focus-within {
    z-index: 10;
  }

  /* Borders always visible, no glow at rest */
  #sec-01, #sec-05 { border: 1.5px solid rgba(233,41,93,0.18); }
  #sec-02, #sec-06 { border: 1.5px solid rgba(63,211,213,0.18); }
  #sec-03, #sec-07 { border: 1.5px solid rgba(254,200,67,0.25); }
  #sec-04          { border: 1.5px solid rgba(159,106,205,0.18); }

  /* Glow transitions in when card is active */
  #sec-01:focus-within, #sec-05:focus-within { box-shadow: 0 4px 32px rgba(233,41,93,0.22), 0 1px 4px rgba(0,0,0,0.04); }
  #sec-02:focus-within, #sec-06:focus-within { box-shadow: 0 4px 32px rgba(63,211,213,0.22), 0 1px 4px rgba(0,0,0,0.04); }
  #sec-03:focus-within, #sec-07:focus-within { box-shadow: 0 4px 32px rgba(254,200,67,0.28), 0 1px 4px rgba(0,0,0,0.04); }
  #sec-04:focus-within                        { box-shadow: 0 4px 32px rgba(159,106,205,0.22), 0 1px 4px rgba(0,0,0,0.04); }

  @keyframes sectionIn {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── SECTION HEADER ── */
  .section__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 24px;
  }

  /* Left side: number + title stacked */
  .section__head-left {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    flex: 1;
  }

  /* Number badge – circle like the reference */
  .section__num {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border-radius: 50%;
    background: var(--clr, var(--pink));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: #fff;
  }

  /* Big decorative icon – top-right of the card */
  .section__icon-bg {
    flex-shrink: 0;
    width: 100px; height: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: -8px;
  }
  .section__icon-bg img {
    width: 100px; height: 100px;
    object-fit: contain;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.08));
  }

  /* ── SVG underline under section title ── */
  .section__title-wrap {
    display: inline-flex;
    flex-direction: column;
    gap: 1px;
  }

  .section__title {
    font-size: 1.25rem;
    font-weight: 900;
    color: var(--black);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    line-height: 1.2;
  }

  /* Wraps just the h2 + SVG so underline only spans the title text, not the opt-badge */
  .section__title-underline-wrap {
    display: inline-flex;
    flex-direction: column;
    width: fit-content; /* This breaks the flex stretch and snaps the line to the text width */
  }

  .section__title-underline {
    display: block;
    width: 100%;
    height: 5px;
    margin-top: -2px;
    flex-shrink: 0;
  }

  /* Colour the underline SVG fill per section */
  #sec-01 .section__title-underline path,
  #sec-05 .section__title-underline path { fill: var(--pink); }
  #sec-02 .section__title-underline path,
  #sec-06 .section__title-underline path { fill: var(--teal); }
  #sec-03 .section__title-underline path,
  #sec-07 .section__title-underline path { fill: var(--yellow); }
  #sec-04 .section__title-underline path { fill: var(--purple); }

  .section__sub {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--muted);
    margin-top: 4px;
  }

  /* Title row: title + opt-badge side by side, underline only under title */
  .section__title-row {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .section__instructions {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 16px;
    background: color-mix(in srgb, var(--sec-clr, var(--pink)) 14%, transparent);
    padding: 10px 14px;
    border-radius: 10px;
  }
  .section__instructions strong { color: var(--black); }
  kbd {
    background: var(--off);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 1px 6px;
    font-family: 'Raleway', sans-serif;
    font-size: 0.8em;
    font-weight: 700;
  }

  /* ── FIELD GRID ── */
  .fields { display: grid; gap: 16px; }
  .fields--2 { grid-template-columns: 1fr 1fr; }
  .fields--3 { grid-template-columns: 1fr 1fr 1fr; }
  /* Identity: name takes ~2/3, initials ~1/3 on row 1; nickname spans full on row 2 */
  .fields--identity { grid-template-columns: 2fr 1fr; }
  .field--full { grid-column: 1 / -1; }
  .field--nickname { grid-column: 1 / 2; } /* same width as the name field above */

  /* ── FIELD ── */
  .field { display: flex; flex-direction: column; gap: 5px; }

  .label {
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--black);
  }
  .req { color: var(--pink); font-size: 1rem; font-weight: 800; }
  .opt {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: 0.02em;
    margin-left: 4px;
  }

  /* ── INPUTS ── */
  .input {
    width: 100%;
    font-family: 'Raleway', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--black);
    background: var(--off);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 11px 14px;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
    appearance: none;
  }
  .input:focus {
    border-color: var(--sec-clr, var(--pink));
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--sec-clr, var(--pink)) 15%, transparent);
    background: var(--white);
  }
  .input.is-error {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239,68,68,0.1);
  }

  /* Per-section active color token */
  #sec-01, #sec-05 { --sec-clr: var(--pink); }
  #sec-02, #sec-06 { --sec-clr: var(--teal); }
  #sec-03, #sec-07 { --sec-clr: var(--yellow); }
  #sec-04          { --sec-clr: var(--purple); }

  .textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.6;
  }

  /* ── CATEGORY CUSTOM DROPDOWN ── */
  .category-dd-wrap {
    position: relative;
    width: 100%;
  }
  .category-dd-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    cursor: pointer;
    text-align: left;
    font-weight: 600;
    color: var(--muted);
  }
  .category-dd-trigger.has-value { color: var(--black); }
  .category-dd-trigger:hover,
  .category-dd-trigger.is-open { border-color: var(--teal); background: var(--white); }
  .category-dd-trigger:focus { outline: none; }

  .category-dd-label { flex: 1; }

  .category-dd-caret {
    width: 16px; height: 16px;
    flex-shrink: 0;
    color: var(--muted);
    transition: transform 0.2s;
  }
  .category-dd-trigger.is-open .category-dd-caret { transform: rotate(180deg); }

  .category-dd-list {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    width: 100%;
    background: var(--white);
    border: 1.5px solid rgba(63,211,213,0.35);
    border-radius: 13px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
    z-index: 100;
    list-style: none;
    padding: 6px;
    overflow: hidden;
  }

  .category-dd-item {
    padding: 10px 12px;
    border-radius: 8px;
    font-family: 'Raleway', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--black);
    cursor: pointer;
    transition: background 0.15s;
  }
  .category-dd-item:hover { background: rgba(63,211,213,0.1); }
  .category-dd-item.is-selected {
    background: rgba(63,211,213,0.14);
    color: var(--black);
  }

  .hint {
    font-size: 0.73rem;
    font-weight: 500;
    color: var(--muted);
    line-height: 1.4;
  }

  .err {
    font-size: 0.73rem;
    font-weight: 600;
    color: #ef4444;
    display: block;
  }
  .err:empty { display: none; }

  /* ── TAG INPUT ── */
  .tag-input-wrap {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .tag-input-row {
    display: flex;
    gap: 0;
    align-items: center;
    background: var(--off);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 5px 5px 5px 0;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .tag-input-row:focus-within {
    border-color: var(--yellow);
    box-shadow: 0 0 0 3px rgba(254,200,67,0.15);
    background: var(--white);
  }

  .tag-input {
    flex: 1;
    background: transparent;
    border: none !important;
    box-shadow: none !important;
    border-radius: 0;
    padding: 10px 16px;
    font-size: 0.92rem;
  }
  .tag-input:focus {
    border-color: transparent !important;
    box-shadow: none !important;
    background: transparent !important;
  }

  .add-tag-btn {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: var(--yellow);
    color: var(--white);
    font-family: 'Raleway', sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 10px 20px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: background 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }
  .add-tag-btn:hover {
    box-shadow: 0 0 0 3px rgba(254,200,67,0.35), 0 2px 10px rgba(254,200,67,0.45);
  }
  .add-tag-btn:active {
    box-shadow: 0 0 0 4px rgba(254,200,67,0.45), 0 2px 14px rgba(254,200,67,0.55);
  }
  .add-tag-btn svg { width: 14px; height: 14px; stroke: var(--white); }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    min-height: 0;
  }

  /* Tags — solid pastel pills matching reference image */
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px 8px 16px;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    border: none;
    animation: tagPop 0.22s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  @keyframes tagPop {
    from { transform: scale(0.6); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }
  .tag[data-ci="0"] { background: #FFCCD9; color: #C41E4A; }
  .tag[data-ci="1"] { background: #C4F2F2; color: #0A7E80; }
  .tag[data-ci="2"] { background: #FFF0B3; color: #8A6000; }
  .tag[data-ci="3"] { background: #E8D5F5; color: #6A35A8; }

  .tag-remove {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px; height: 20px;
    border-radius: 50%;
    opacity: 0.75;
    transition: opacity 0.15s, background 0.15s;
    color: inherit;
    flex-shrink: 0;
    font-style: normal;
  }
  .tag-remove:hover { opacity: 1; background: rgba(0,0,0,0.1); }
  .tag-remove svg { width: 11px; height: 11px; stroke-width: 2; }

  /* ── BIO EXTRAS ── */
  .bio-extract-row {
    margin-bottom: 16px;
  }

  .bio-file-wrap {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 6px;
    flex-wrap: wrap;
  }

  .bio-file-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--off);
    border: 1.5px dashed var(--border);
    border-radius: 10px;
    padding: 9px 16px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .bio-file-label:hover {
    border-color: var(--teal);
    color: var(--teal);
  }
  .bio-file-label svg { width: 16px; height: 16px; flex-shrink: 0; }
  .bio-file-input { display: none; }

  .bio-file-note {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--teal);
  }

  .bio-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 4px;
  }

  .char-count {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    white-space: nowrap;
  }
  .char-count.over { color: #ef4444; }

  /* ── OPTIONAL BADGE CLEANUP ── */
  .opt-badge {
    font-size: 0.72rem;
    font-weight: 900;          /* Reduced boldness from heavy to semi-bold */
    letter-spacing: normal;    /* Removes the squeeze, resets to default tracking */
    color: var(--black);       /* Keeps the color pure black */
    background: none;
    border: none;
    padding: 0;
    text-transform: uppercase;
    display: inline-block;
    width: fit-content;
    margin-left: 4px;
    vertical-align: baseline;
  }

  /* Resets the tracking for the parentheses back to normal */
  .opt-badge::before { 
    content: '('; 
    margin-right: 0;
  }
  .opt-badge::after { 
    content: ')'; 
    margin-left: 0;
  }

  /* ── SOCIALS BUILDER ── */
  .socials-builder {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 14px;
  }

  .social-row {
    display: grid;
    grid-template-columns: 200px 1fr 40px;
    gap: 10px;
    align-items: center;
  }

  /* ── CUSTOM SOCIAL DROPDOWN ── */
  .social-select-wrap {
    position: relative;
    width: 100%;
  }

  .social-dropdown {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Raleway', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--black);
    background: var(--off);
    border: 1.5px solid var(--border);
    border-radius: 11px;
    padding: 9px 12px;
    cursor: pointer;
    outline: none;
    text-align: left;
    transition: border-color 0.2s, background 0.2s;
    position: relative;
  }
  .social-dropdown:hover,
  .social-dropdown.is-open { border-color: var(--teal); background: var(--white); }

  .social-dd-icon {
    width: 18px; height: 18px;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: var(--teal);
  }
  .social-dd-icon svg { width: 18px; height: 18px; }

  .social-dd-label { flex: 1; }

  .social-dd-caret {
    width: 14px; height: 14px;
    color: var(--muted);
    flex-shrink: 0;
    transition: transform 0.2s;
    display: flex; align-items: center; justify-content: center;
  }
  .social-dd-caret svg { width: 14px; height: 14px; }
  .social-dropdown.is-open .social-dd-caret { transform: rotate(180deg); }

  .social-dd-list {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    width: 100%;
    background: var(--white);
    border: 1.5px solid rgba(63,211,213,0.35);
    border-radius: 13px;
    box-shadow: 0 8px 28px rgba(0,0,0,0.12);
    z-index: 100;
    list-style: none;
    padding: 6px;
    overflow-y: visible;
  }

  .social-dd-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border-radius: 8px;
    font-family: 'Raleway', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--black);
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .social-dd-item:hover { background: rgba(63,211,213,0.1); color: var(--black); }
  .social-dd-item.is-selected {
    background: rgba(63,211,213,0.14);
    color: var(--black);
  }
  .social-dd-item.is-selected .social-dd-item-icon { color: var(--teal); }

  .social-dd-item-icon {
    width: 18px; height: 18px;
    flex-shrink: 0;
    color: var(--muted);
    display: flex; align-items: center; justify-content: center;
    transition: color 0.15s;
  }
  .social-dd-item-icon svg { width: 18px; height: 18px; }
  .social-dd-item:hover .social-dd-item-icon { color: var(--teal); }

  .social-url {
    font-family: 'Raleway', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--black);
    background: var(--off);
    border: 1.5px solid var(--border);
    border-radius: 11px;
    padding: 10px 14px;
    outline: none;
    width: 100%;
    transition: border-color 0.2s;
  }
  .social-url:focus {
    border-color: var(--teal);
    background: var(--white);
  }

  .social-remove {
    width: 36px; height: 36px;
    background: none;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--teal);
    flex-shrink: 0;
    transition: opacity 0.2s, color 0.2s, transform 0.2s;
  }
  .social-remove:hover {
    color: var(--teal);
    opacity: 1;
    transform: scale(1.1);
  }
  .social-remove svg { width: 22px; height: 22px; }

  .add-social-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: none;
    border: 1.5px dashed rgba(63,211,213,0.5);
    color: var(--teal);
    font-family: 'Raleway', sans-serif;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    padding: 10px 20px;
    border-radius: 11px;
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .add-social-btn:hover {
    background: rgba(63,211,213,0.06);
    border-color: var(--teal);
  }
  .add-social-btn svg { width: 14px; height: 14px; }

  /* ── PHOTO UPLOAD ── */
  .photo-layout {
    display: grid;
    grid-template-columns: 1.6fr 1px 1fr 1fr;
    gap: 0 24px;
    align-items: start;
    margin-top: 16px;
  }

  .upload-zone {
    position: relative;
    border: 2px dashed rgba(26,26,26,0.15);
    border-radius: 16px;
    background: transparent;
    transition: border-color 0.2s, background 0.2s;
    overflow: hidden;
    cursor: pointer;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .upload-zone:hover { border-color: rgba(26,26,26,0.3); }
  .upload-zone.dragover {
    border-color: var(--yellow);
    background: rgba(254,200,67,0.04);
  }
  .upload-input {
    position: absolute; inset: 0;
    opacity: 0; cursor: pointer;
    width: 100%; height: 100%;
  }
  .upload-ui {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px;
    pointer-events: none;
  }
  .upload-icon { width: 44px; height: 44px; }
  .upload-text {
    font-size: 0.86rem;
    font-weight: 700;
    color: var(--black);
    text-align: center;
    line-height: 1.5;
  }
  .upload-hint {
    font-size: 0.73rem;
    font-weight: 500;
    color: var(--muted);
  }

  /* Upload col wrapper — spacer matches PREVIEW label so image bottoms align */
  .upload-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .upload-spacer {
    display: block;
    height: 0.62rem; /* matches preview-label font-size line height */
    line-height: 1;
    visibility: hidden;
  }

  /* Middle col: label sits on top, image below — top-aligned with upload zone */
  .photo-preview-col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 6px;
  }
  .preview-label {
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
    padding-left: 2px;
  }
  .photo-preview-card {
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: 18px;
    background: none;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-preview-card img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Vertical divider between upload and preview */
  .photo-divider-v {
    width: 1px;
    background: var(--border);
    align-self: stretch;
    margin-top: 22px; /* below PREVIEW label height */
  }

  /* Right col: no-photo note top-aligned */
  .no-photo-note {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 4px;
    padding-top: 22px;
  }
  .no-photo-deco { width: 72px; height: auto; }
  .no-photo-text {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--muted);
    line-height: 1.6;
  }
  .no-photo-text strong {
    color: var(--yellow);
    font-weight: 800;
    display: block;
    margin-bottom: 4px;
    font-size: 0.86rem;
  }


  /* ── SUBMIT STRIP ── */
  .submit-strip {
    background: var(--white);
    border-radius: 24px;
    padding: 32px 40px;
    margin-top: 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
  }

  .submit-note {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--muted);
    max-width: 280px;
    line-height: 1.5;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--pink);
    color: white;
    font-family: 'Raleway', sans-serif;
    font-size: 0.88rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    padding: 15px 30px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(233,41,93,0.4);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }
  .submit-btn:hover {
    background: #d4234f;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(233,41,93,0.5);
  }
  .submit-btn:disabled {
    opacity: 0.55; cursor: not-allowed; transform: none;
  }

  /* ── REVIEW MODAL ── */
  .review-overlay {
    position: fixed; inset: 0; z-index: 999;
    background: rgba(26,26,26,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    animation: fadeIn 0.2s ease;
  }
  @keyframes fadeIn {
    from { opacity: 0; } to { opacity: 1; }
  }

  .review-modal {
    background: var(--white);
    border-radius: 28px;
    padding: 40px;
    max-width: 680px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    animation: modalSlide 0.3s cubic-bezier(0.34,1.56,0.64,1) both;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  }
  @keyframes modalSlide {
    from { transform: translateY(24px) scale(0.96); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }

  .review-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.4rem;
    font-weight: 900;
    color: var(--black);
    margin-bottom: 8px;
  }
  .review-title img { width: 36px; height: 36px; }

  .review-sub {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    margin-bottom: 24px;
  }

  .review-body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 28px;
  }

  .review-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
  }
  .review-row:last-child { border-bottom: none; }

  .review-key {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-transform: uppercase;
    padding-top: 2px;
  }
  .review-val {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--black);
    line-height: 1.55;
    word-break: break-word;
  }
  .review-val .tag {
    font-size: 0.72rem;
    padding: 3px 10px;
  }

  .review-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    flex-wrap: wrap;
  }

  .btn-edit {
    background: none;
    border: 1.5px solid var(--border);
    color: var(--muted);
    font-family: 'Raleway', sans-serif;
    font-size: 0.84rem;
    font-weight: 700;
    padding: 13px 24px;
    border-radius: 999px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-edit:hover { border-color: var(--pink); color: var(--pink); }

  .btn-confirm {
    background: var(--pink);
    border: none;
    color: white;
    font-family: 'Raleway', sans-serif;
    font-size: 0.84rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    padding: 13px 28px;
    border-radius: 999px;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(233,41,93,0.35);
    transition: background 0.2s, transform 0.15s;
  }
  .btn-confirm:hover {
    background: #d4234f;
    transform: translateY(-1px);
  }
  .btn-confirm:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }

  /* ── SUCCESS STATE ── */
  .success-state {
    text-align: center;
    padding: 80px 40px;
    background: var(--white);
    border-radius: 28px;
    margin-top: 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    position: relative;
  }
  .success-sparks {
    position: absolute;
    top: 24px; right: 24px;
    width: 48px;
    opacity: 0.7;
  }
  .success-check {
    width: 72px; height: 72px;
    margin: 0 auto 20px;
    animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
  }
  @keyframes popIn {
    from { transform: scale(0); opacity: 0; }
    to   { transform: scale(1); opacity: 1; }
  }
  .success-title {
    font-size: 2rem;
    font-weight: 900;
    color: var(--black);
    margin-bottom: 12px;
  }
  .success-text {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--muted);
    line-height: 1.65;
    max-width: 400px;
    margin: 0 auto 24px;
  }
  .success-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    color: var(--pink);
    background: rgba(233,41,93,0.07);
    border: 1.5px solid rgba(233,41,93,0.2);
    padding: 8px 20px;
    border-radius: 999px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 680px) {
    .hero { padding: 48px 20px 56px; }
    .section { padding: 28px 22px; }
    .fields--2, .fields--3 { grid-template-columns: 1fr; }
    .fields--identity { grid-template-columns: 2fr 1fr; gap: 12px; }
    .field--nickname { grid-column: 1 / 2; margin-top: 0; }
    .field--full { grid-column: 1; }
    .social-row { grid-template-columns: 1fr 40px; }
    .social-select-wrap { grid-column: 1 / -1; }
    .social-url { grid-column: 1; }
    .social-remove { grid-column: 2; grid-row: 2; }
    .submit-strip { flex-direction: column; align-items: stretch; padding: 24px 22px; }
    .submit-btn { justify-content: center; width: 100%; }
    .review-modal { padding: 28px 22px; }
    .review-row { grid-template-columns: 1fr; gap: 4px; }
    .review-actions { flex-direction: column-reverse; }
    .btn-edit, .btn-confirm { width: 100%; text-align: center; justify-content: center; }
    /* hide smaller decos on mobile */
    .deco--crown, .deco--film, .deco--arrow, .deco--starline { display: none; }
    /* shrink section icons so they don't overflow/crop on small cards */
    .section__icon-bg {
      width: 60px; height: 60px;
      margin-top: 0;
    }
    .section__icon-bg img {
      width: 60px; height: 60px;
    }
    /* photo section on mobile */
    .photo-avatar-wrap { width: 68px; height: 68px; }
    .photo-layout { grid-template-columns: 1fr; }
    .photo-divider-v { display: none; }
    .photo-preview-col {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      width: 100%;
      margin-top: 20px;
    }
    .photo-preview-col .preview-label {
      order: -1;
      font-size: 0.72rem;
    }
    .photo-preview-card {
      width: 100%;
      max-width: 100%;
    }
    .no-photo-note { flex-direction: row; align-items: flex-start; padding-left: 0; }
  }
  /* ── FOOTER ── */
  .site-footer {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 24px 40px;
    margin-top: 8px;
  }
  .footer-logo {
    height: 72px;
    width: auto;
    transition: opacity 0.2s;
    display: block;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 680px) {
    .hero { padding: 48px 20px 56px; }

    /* Fix: Scale sparks and pull them closer to the shrinking text */
    .sparks-inline {
      width: 22px;
      right: -36px;
      bottom: 35px;
    }

    .section { padding: 28px 22px; }
    .fields--2, .fields--3 { grid-template-columns: 1fr; }
    /* ... the rest of your existing mobile styles ... */
  }

  @media (max-width: 680px) {
    .site-footer { padding: 40px 24px 32px; }
    .footer-logo { height: 42px; }
  }
</style>

